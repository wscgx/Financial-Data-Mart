# ============================================================
# Financial Data Mart - 环境变量配置模板
# ============================================================
# 复制此文件为 .env 并填写实际值
# cp .env.example .env

# MySQL
MYSQL_ROOT_PASSWORD=your_mysql_root_password
MYSQL_DATABASE=financial_dw

# MinIO
MINIO_ROOT_USER=your_minio_user
MINIO_ROOT_PASSWORD=your_minio_password

# PostgreSQL (Airflow 元数据库)
POSTGRES_USER=airflow
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=airflow

# Airflow
AIRFLOW_FERNET_KEY=your_airflow_fernet_key
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=your_airflow_admin_password

# Spark
SPARK_WORKER_MEMORY=2g
SPARK_WORKER_CORES=2

# Jupyter
JUPYTER_TOKEN=your_jupyter_token
